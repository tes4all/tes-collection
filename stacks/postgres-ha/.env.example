# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Postgres HA Golden Stack — Environment Configuration                       ║
# ║  Copy this file to .env and adjust values for your environment.             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Network Driver ──────────────────────────────────────────────────────────
# Set to "bridge" for local Docker Compose, "overlay" for Docker Swarm.
NETWORK_DRIVER=overlay

# ─── Passwords ───────────────────────────────────────────────────────────────
# ⚠️  CHANGE THESE IN PRODUCTION! Defaults are for local development only.
# For Docker Swarm production, prefer Docker Secrets over env vars (see README).
POSTGRES_PASSWORD=<postgres_password_placeholder>
REPLICATOR_PASSWORD=<replicator_password_placeholder>
ADMIN_PASSWORD=<admin_password_placeholder>

# ─── Image Tags (optional overrides) ────────────────────────────────────────
# PATRONI_IMAGE=postgres-ha/patroni:18.1
# HAPROXY_IMAGE=postgres-ha/haproxy:3.0.7
# PGBACKREST_IMAGE=postgres-ha/pgbackrest:18.1
