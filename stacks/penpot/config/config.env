# Penpot Configuration
# --------------------

# --- General ---
# The public URL where Penpot will be accessible
PENPOT_PUBLIC_URI=http://localhost:9001

# --- Database (PostgreSQL) ---
# External Postgres connection details
# Connect to the Load Balancer (postgres-lb) or primary node
PENPOT_DATABASE_URI=postgresql://penpot:<penpot_db_password_placeholder>@postgres-lb:5432/penpot
PENPOT_DATABASE_USERNAME=penpot
PENPOT_DATABASE_PASSWORD=<penpot_db_password_placeholder>

# --- Redis (Valkey) ---
# External Redis/Valkey connection details
PENPOT_REDIS_URI=redis://valkey-ha:6379/0

# --- Storage (Assets/Objects-v2) ---
# We use local filesystem for assets by default in this config.
# To use S3 (e.g. MinIO/RustFS), uncomment and configure the following:

# PENPOT_OBJECTS_STORAGE_BACKEND=s3
# PENPOT_OBJECTS_STORAGE_S3_ENDPOINT=http://rustfs:9000
# PENPOT_OBJECTS_STORAGE_S3_BUCKET=penpot
# PENPOT_OBJECTS_STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=<aws_access_key_placeholder>
# AWS_SECRET_ACCESS_KEY=<aws_secret_key_placeholder>

# Note: PENPOT_ASSETS_STORAGE_BACKEND is deprecated in favor of PENPOT_OBJECTS_STORAGE_BACKEND

# --- Security ---
# A 512-bit random key is recommended. Required for backend and exporter.
PENPOT_SECRET_KEY=<penpot_secret_key_placeholder>

# --- Email (SMTP) ---
# Configure your SMTP server here.
# Leaving these default often means no email sending.
# PENPOT_SMTP_DEFAULT_FROM=no-reply@example.com
# PENPOT_SMTP_DEFAULT_REPLY_TO=no-reply@example.com
# PENPOT_SMTP_HOST=smtp.example.com
# PENPOT_SMTP_PORT=587
# PENPOT_SMTP_USERNAME=
# PENPOT_SMTP_PASSWORD=
# PENPOT_SMTP_TLS=true
# PENPOT_SMTP_SSL=false

# --- Telemetry ---
# Disable telemetry for privacy/enterprise environments
PENPOT_TELEMETRY_ENABLED=false

# --- Flags ---
# various feature flags
PENPOT_FLAGS="disable-registration disable-login-with-password"
# (Adjust flags as needed. Typically you want registration enabled initially)
# Resetting to default for initial setup:
PENPOT_FLAGS=""
